# Supabase (existing)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Direct Postgres (optional) — needed for `npm run db:apply-enrollments` / local DDL
# Copy URI from Supabase → Project Settings → Database → Connection string (Session mode or Direct)
# DATABASE_URL=postgresql://postgres.[ref]:[YOUR-PASSWORD]@aws-0-[region].pooler.supabase.com:6543/postgres
# Or set only the DB password (same as in Dashboard → Database password):
# SUPABASE_DB_PASSWORD=

# PayPal Advanced Checkout
# Get credentials from https://developer.paypal.com/dashboard/
NEXT_PUBLIC_PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# Use "sandbox" for testing, "live" for production
PAYPAL_ENVIRONMENT=sandbox

# Optional: override API base (defaults based on PAYPAL_ENVIRONMENT)
# PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
# PAYPAL_API_BASE=https://api-m.paypal.com
